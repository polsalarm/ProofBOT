{
  "name": "@proofbot/contracts",
  "version": "0.1.0",
  "private": true,
  "type": "commonjs",
  "description": "ProofBOT immutable wallet-bound content hash registry",
  "license": "MIT",
  "scripts": {
    "build": "pnpm run export:abi",
    "clean": "hardhat clean",
    "compile": "hardhat compile",
    "coverage": "hardhat coverage",
    "deploy:mainnet": "hardhat deploy-proofbot --network botchainMainnet",
    "deploy:testnet": "hardhat deploy-proofbot --network botchainTestnet",
    "export:abi": "hardhat compile && hardhat run --no-compile scripts/export-abi.ts",
    "test": "hardhat test",
    "typecheck": "hardhat compile && tsc --noEmit"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-ethers": "3.1.3",
    "@nomicfoundation/hardhat-network-helpers": "1.1.2",
    "@nomicfoundation/hardhat-toolbox": "6.1.2",
    "@types/chai": "4.3.20",
    "@types/mocha": "10.0.10",
    "@types/node": "22.20.1",
    "chai": "4.5.0",
    "dotenv": "17.4.2",
    "ethers": "6.17.0",
    "hardhat": "2.28.6",
    "solidity-coverage": "0.8.17",
    "ts-node": "10.9.2",
    "typescript": "5.9.3"
  }
}
