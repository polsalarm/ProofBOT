# Official BOT Chain public RPC values. Replace only with trusted endpoints.
BOTCHAIN_MAINNET_RPC_URL=https://rpc.botchain.ai
BOTCHAIN_TESTNET_RPC_URL=https://rpc.bohr.life
BOTCHAIN_TESTNET_CHAIN_ID=968

# Never commit a populated deployer key. It must be 0x-prefixed and 32 bytes.
DEPLOYER_PRIVATE_KEY=

# Hard safety gate. Mainnet deployment refuses to run unless this is exactly true.
CONFIRM_MAINNET_DEPLOYMENT=false

# Optional receipt confirmations (defaults: mainnet 2, testnet 1).
DEPLOYMENT_CONFIRMATIONS=

# Optional Blockscout-compatible verification configuration. The official docs
# currently document a manual verification UI, not an API, so these stay empty.
BOTCHAIN_EXPLORER_API_URL=
BOTCHAIN_EXPLORER_API_KEY=
BOTCHAIN_TESTNET_EXPLORER_API_URL=
BOTCHAIN_TESTNET_EXPLORER_API_KEY=
