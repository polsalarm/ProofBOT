# Official BOT Chain mainnet values. Override the RPC with a logs-capable
# provider if you want the My Proofs history view: the official public RPC
# currently disables eth_getLogs.
NEXT_PUBLIC_BOTCHAIN_CHAIN_ID=677
NEXT_PUBLIC_BOTCHAIN_RPC_URL=https://rpc.botchain.ai
NEXT_PUBLIC_BOTCHAIN_EXPLORER_URL=https://scan.botchain.ai

# Populate these together after deployment. Local development can leave them
# blank and displays a deployment-not-configured state. Production builds
# intentionally fail until both verified values are supplied.
NEXT_PUBLIC_PROOFBOT_CONTRACT_ADDRESS=
NEXT_PUBLIC_PROOFBOT_DEPLOYMENT_BLOCK=

# Maximum block span for creator-filtered event-log queries.
NEXT_PUBLIC_PROOFBOT_LOG_CHUNK_SIZE=5000
