# Selects which BOT Chain network this build targets. Must be "testnet" or
# "mainnet" — there is no silent fallback. Each deployed build should target
# exactly one network; never mix testnet and mainnet values below.
NEXT_PUBLIC_BOTCHAIN_NETWORK=testnet

# Chain ID must match the selected network above, or the build fails:
#   testnet -> 968
#   mainnet -> 677
NEXT_PUBLIC_BOTCHAIN_CHAIN_ID=968

# RPC and explorer for the selected network. Override only with trusted,
# reviewed endpoints. The public mainnet RPC currently disables
# eth_getLogs — override it with a logs-capable provider if you want the
# My Proofs history view.
#   testnet defaults -> https://rpc.bohr.life / https://scan.bohr.life
#   mainnet defaults -> https://rpc.botchain.ai / https://scan.botchain.ai
NEXT_PUBLIC_BOTCHAIN_RPC_URL=https://rpc.bohr.life
NEXT_PUBLIC_BOTCHAIN_EXPLORER_URL=https://scan.bohr.life

# Populate these together after deployment on the selected network. Local
# development can leave them blank and displays a deployment-not-configured
# state. Production builds intentionally fail until both verified values are
# supplied.
NEXT_PUBLIC_PROOFBOT_CONTRACT_ADDRESS=
NEXT_PUBLIC_PROOFBOT_DEPLOYMENT_BLOCK=

# Maximum block span for creator-filtered event-log queries.
NEXT_PUBLIC_PROOFBOT_LOG_CHUNK_SIZE=5000
